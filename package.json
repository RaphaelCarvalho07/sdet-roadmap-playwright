{
  "name": "sdet-roadmap-playwright",
  "version": "1.0.0",
  "description": "Pragmatic roadmap and technical implementation for transitioning from QA Automation to Software Development Engineer in Test (SDET) using TypeScript and Playwright.",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "test": "playwright test",
    "test:api": "playwright test --project=api-tests",
    "test:ui": "npx playwright test --project=ui-tests-chrome",
    "test:ui:visual": "npx playwright test --ui --project=ui-tests-chrome",
    "test:ui:crossbrowser": "playwright test --project=ui-tests-chrome --project=ui-tests-firefox --project=ui-tests-webkit",
    "report": "npx playwright show-report"
  },
  "keywords": [],
  "author": "Raphael 'Rapha' Carvalho",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-plugin-playwright": "^2.10.4",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.62.0",
    "zod": "^4.4.3"
  }
}
